# AI provider: auto, openai, local, or fallback.
AI_PROVIDER=auto

# Cloud provider. Vision/custom-brand routes still use OpenAI when configured.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini

# llama.cpp or another OpenAI-compatible local server.
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=card-designer-local
LOCAL_LLM_CONCEPT_COUNT=2
LOCAL_LLM_MAX_TOKENS=430
LOCAL_LLM_TIMEOUT_MS=180000
LOCAL_LLM_API_KEY=
